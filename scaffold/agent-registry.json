{
  "schema_version": "2.0",
  "agents": [
    {
      "name": "dw-code-explorer",
      "module": "core",
      "mode": "read-only",
      "description": "Trace entry points, flows, dependencies, and existing patterns before planning or fixing code.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["unfamiliar code", "planning research", "wide grep or dependency tracing"],
      "avoid_when": ["small direct edit", "needs full parent conversation", "implementation is already obvious"]
    },
    {
      "name": "dw-planner",
      "module": "core",
      "mode": "read-only",
      "description": "Turn requirements into implementation slices, dependencies, risks, and verification criteria.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["planning research", "task decomposition", "risk mapping"],
      "avoid_when": ["small direct edit", "requirements need user clarification", "implementation and planning are tightly coupled"]
    },
    {
      "name": "dw-build-fixer",
      "module": "core",
      "mode": "write",
      "description": "Fix build, typecheck, and lint failures with minimal diffs.",
      "context_mode": "fresh",
      "tool_policy": "write-scoped",
      "max_turns": 12,
      "input_budget_words": 1200,
      "output_budget_words": 1200,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["failing build command", "typecheck failure", "lint failure after a known command"],
      "avoid_when": ["no failing command exists", "fix needs architecture decision", "write scope is unclear"]
    },
    {
      "name": "dw-code-reviewer",
      "module": "core",
      "mode": "read-only",
      "description": "Review changed code for correctness, maintainability, and defensible risks.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["independent code review", "PR readiness", "changed files with clear diff"],
      "avoid_when": ["implementation is still moving", "no files or diff are provided", "style-only preference review"]
    },
    {
      "name": "dw-test-author",
      "module": "core",
      "mode": "write",
      "description": "Add focused tests and regression coverage using project conventions.",
      "context_mode": "fresh",
      "tool_policy": "write-scoped",
      "max_turns": 12,
      "input_budget_words": 1200,
      "output_budget_words": 1200,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["focused regression coverage", "clear invariant to test", "known nearby test pattern"],
      "avoid_when": ["behavior is unspecified", "test suite architecture needs redesign", "write scope is unclear"]
    },
    {
      "name": "dw-security-reviewer",
      "module": "security",
      "mode": "read-only",
      "description": "Review sensitive surfaces such as auth, secrets, uploads, SQL, SSRF, and XSS.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["auth or authorization changes", "input boundary review", "supply-chain or secret risk"],
      "avoid_when": ["purely cosmetic diff", "no sensitive surface is involved", "requires exploit research outside repo scope"]
    },
    {
      "name": "dw-silent-failure-hunter",
      "module": "security",
      "mode": "read-only",
      "description": "Find swallowed errors, dangerous fallbacks, lost stack traces, and missing propagation.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["error handling review", "async detachment review", "fallback or retry changes"],
      "avoid_when": ["no error path changed", "requires broad audit beyond input packet", "implementation is still in progress"]
    },
    {
      "name": "dw-qa-runner",
      "module": "frontend",
      "mode": "write-qa",
      "description": "Create and run UI/API QA scripts, evidence, and retest logs under QA folders.",
      "context_mode": "fresh",
      "tool_policy": "qa-write",
      "max_turns": 16,
      "input_budget_words": 1200,
      "output_budget_words": 1500,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["behavior-level QA", "Playwright or API flow validation", "retest evidence collection"],
      "avoid_when": ["unit-only change", "environment cannot run", "bug fixing was not assigned"]
    },
    {
      "name": "dw-typescript-reviewer",
      "module": "typescript",
      "mode": "read-only",
      "description": "Review TypeScript and JavaScript changes for type safety, async correctness, and web or Node risks.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["TypeScript or JavaScript diff review", "React or Node boundary changes", "type safety review"],
      "avoid_when": ["global audit without paths", "non-TypeScript diff", "style-only review"]
    },
    {
      "name": "dw-typescript-build-fixer",
      "module": "typescript",
      "mode": "write",
      "description": "Fix TypeScript and JavaScript build/type errors with minimal changes.",
      "context_mode": "fresh",
      "tool_policy": "write-scoped",
      "max_turns": 12,
      "input_budget_words": 1200,
      "output_budget_words": 1200,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["TypeScript typecheck failure", "JavaScript build failure", "failing lint command"],
      "avoid_when": ["no failing command exists", "fix requires API redesign", "strictness would need to be weakened"]
    },
    {
      "name": "dw-python-reviewer",
      "module": "python",
      "mode": "read-only",
      "description": "Review Python changes for correctness, typing, async behavior, and framework risks.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["Python diff review", "async or exception handling review", "framework boundary review"],
      "avoid_when": ["global audit without paths", "non-Python diff", "style-only review"]
    },
    {
      "name": "dw-python-build-fixer",
      "module": "python",
      "mode": "write",
      "description": "Fix Python test, import, typing, and packaging failures with minimal changes.",
      "context_mode": "fresh",
      "tool_policy": "write-scoped",
      "max_turns": 12,
      "input_budget_words": 1200,
      "output_budget_words": 1200,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["pytest failure", "ruff or mypy failure", "import or packaging failure"],
      "avoid_when": ["no failing command exists", "behavior change is not proven", "dependency decision is required"]
    },
    {
      "name": "dw-csharp-reviewer",
      "module": "csharp",
      "mode": "read-only",
      "description": "Review C#/.NET code for API, async, dependency injection, and data-access risks.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["C# or .NET diff review", "DI or async review", "EF/data access review"],
      "avoid_when": ["global audit without paths", "non-.NET diff", "style-only review"]
    },
    {
      "name": "dw-dotnet-build-fixer",
      "module": "csharp",
      "mode": "write",
      "description": "Fix .NET build, test, restore, and analyzer failures with minimal changes.",
      "context_mode": "fresh",
      "tool_policy": "write-scoped",
      "max_turns": 12,
      "input_budget_words": 1200,
      "output_budget_words": 1200,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["dotnet restore failure", "dotnet build or test failure", "analyzer failure"],
      "avoid_when": ["no failing command exists", "package or framework decision is required", "project structure redesign is needed"]
    },
    {
      "name": "dw-rust-reviewer",
      "module": "rust",
      "mode": "read-only",
      "description": "Review Rust changes for ownership, error handling, concurrency, unsafe, and API design risks.",
      "context_mode": "fresh",
      "tool_policy": "read-only",
      "max_turns": 8,
      "input_budget_words": 900,
      "output_budget_words": 900,
      "parallel_safe": true,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["Rust diff review", "unsafe or concurrency review", "public API review"],
      "avoid_when": ["global audit without paths", "non-Rust diff", "style-only review"]
    },
    {
      "name": "dw-rust-build-fixer",
      "module": "rust",
      "mode": "write",
      "description": "Fix Rust cargo check/test/clippy failures with minimal changes.",
      "context_mode": "fresh",
      "tool_policy": "write-scoped",
      "max_turns": 12,
      "input_budget_words": 1200,
      "output_budget_words": 1200,
      "parallel_safe": false,
      "handoff_required": true,
      "skill_policy": "lazy",
      "recommended_for": ["cargo check failure", "cargo test failure", "cargo clippy failure"],
      "avoid_when": ["no failing command exists", "public API decision is needed", "warning suppression would be broad"]
    }
  ],
  "commands": {
    "dw-plan": ["dw-code-explorer", "dw-planner"],
    "dw-run": ["dw-build-fixer", "dw-test-author"],
    "dw-bugfix": ["dw-code-explorer", "dw-build-fixer", "dw-test-author", "dw-silent-failure-hunter"],
    "dw-review": ["dw-code-reviewer", "dw-security-reviewer", "dw-silent-failure-hunter"],
    "dw-qa": ["dw-qa-runner", "dw-test-author"],
    "dw-intel": ["dw-code-explorer"],
    "dw-subtask-start": ["dw-code-explorer", "dw-planner", "dw-build-fixer", "dw-test-author"],
    "dw-subtask-complete": [],
    "dw-subtask-resume": []
  }
}
